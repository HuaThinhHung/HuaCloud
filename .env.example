# HuaCloud — sao chép thành .env.local và điền giá trị thật.
# .env.local đã được gitignore — KHÔNG commit secret.

# Database — local dev: SQLite; production: Postgres/Neon.
# Neon: DATABASE_URL = chuỗi POOLED (host có -pooler) + ?sslmode=require&pgbouncer=true&connection_limit=1
#       DIRECT_URL   = chuỗi DIRECT (không -pooler) — chỉ dùng cho prisma migrate.
DATABASE_URL="file:../.data/huacloud.db"
DIRECT_URL=""

# Telegram storage backend (bắt buộc để upload thật)
# Token lấy từ @BotFather. Chat ID lấy bằng: npm run telegram:setup
TELEGRAM_BOT_TOKEN="123456789:AA...your-bot-token..."
TELEGRAM_CHAT_ID="-1001234567890"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Bảo vệ truy cập — đặt APP_USERNAME + APP_PASSWORD khi deploy để yêu cầu đăng nhập.
# APP_USERNAME để TRỐNG = chỉ cần mật khẩu; đặt tên = phải nhập đúng cả tài khoản.
# Để APP_PASSWORD TRỐNG ở local = vào thẳng không cần login. SESSION_SECRET là chuỗi
# ngẫu nhiên bất kỳ để ký cookie (đổi secret hoặc username = đăng xuất mọi phiên).
APP_USERNAME=""
APP_PASSWORD=""
SESSION_SECRET=""

# Cloud storage cho thumbnail/preview khi deploy lên Vercel (Storage → Blob).
# Để trống ở local = thumbnail lưu ổ đĩa .data/ như thường.
BLOB_READ_WRITE_TOKEN=""
# =1 trên Vercel để bật client-upload thẳng lên Blob (né body-limit 4.5MB). Local để trống.
NEXT_PUBLIC_BLOB_ENABLED=""

# AI enrichment (optional — để trống thì tính năng AI tự ẩn, app vẫn là DAM đầy đủ)
GEMINI_API_KEY=""
